#!/bin/bash
# =========================
# PostgreSQL Recovery Script
# =========================
BACKUP_DIR="{{ postgresql_backup_dir }}"

echo "Available backups:"
echo "=================="
ls -lh $BACKUP_DIR/*.sql.gz 2>/dev/null || echo "No backups found!"
echo ""

if [ -z "$1" ]; then
  echo "Usage: pg_recovery.sh <backup_file> <database_name>"
  echo "Example: pg_recovery.sh appspace_db_20240101_020000.sql.gz appspace_db"
  exit 1
fi

BACKUP_FILE="$1"
DB_NAME="$2"

echo "WARNING: This will RESTORE $DB_NAME from $BACKUP_FILE"
read -p "Are you sure? (yes/no): " CONFIRM

if [ "$CONFIRM" != "yes" ]; then
  echo "Recovery cancelled"
  exit 0
fi

echo "Starting recovery..."

sudo -u postgres psql -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname='$DB_NAME';"
sudo -u postgres psql -c "DROP DATABASE IF EXISTS $DB_NAME;"
sudo -u postgres psql -c "CREATE DATABASE $DB_NAME;"

gunzip -c $BACKUP_DIR/$BACKUP_FILE | sudo -u postgres psql $DB_NAME

if [ $? -eq 0 ]; then
  echo "[OK] Recovery SUCCESS - $DB_NAME restored from $BACKUP_FILE"
else
  echo "[FAIL] Recovery FAILED"
  exit 1
fi
