[program:{{ app_name }}]
# Binary hasil build lo sekarang selalu bernama 'artisan'
command={{ app_path }}/artisan
autostart=true
autorestart=true
user={{ app_user }}
directory={{ app_path }}
redirect_stderr=true
stdout_logfile={{ app_path }}/storage/logs/app.log
# Tambahkan ENV sesuai kebutuhan project Go lo
environment=PORT="{{ app_port }}",APP_ENV="production"
stopwaitsecs=3600
