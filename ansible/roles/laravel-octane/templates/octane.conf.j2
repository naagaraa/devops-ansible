[program:{{ app_name }}]
process_name=%(program_name)s_%(process_num)02d
command=php {{ app_path }}/artisan octane:start --server=frankenphp --host={{ octane_host }} --port={{ octane_port }} --admin-port={{ octane_admin_port }}
autostart=true
autorestart=true
user={{ app_user }}
redirect_stderr=true
stdout_logfile={{ app_path }}/storage/logs/octane.log
stopwaitsecs=3600
